# --- Anthropic Claude (server-side; used by /api/process) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Supabase (public; used by client for cloud sync) ---
# These are exposed to the browser. Configure RLS to lock the table to your user.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Optional: a hardcoded device id you want to mark this install with.
# If unset, the app generates one on first run and stores it in localStorage.
NEXT_PUBLIC_DEVICE_ID=
